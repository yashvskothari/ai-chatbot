# ======================================================
# AI-Chatbot - Root .gitignore
# ======================================================

# ==========================
# Backend (Python / FastAPI)
# ==========================
backend/venv/
backend/__pycache__/
backend/.env

backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd

# ==========================
# Frontend (React / Vite)
# ==========================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

frontend/**/*.local

# ==========================
# Logs
# ==========================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================
# IDEs & Editors
# ==========================
.vscode/
!.vscode/extensions.json

.idea/

*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================
# Operating System Files
# ==========================
.DS_Store
Thumbs.db

# ==========================
# Environment Files
# ==========================
.env
.env.*
!.env.example

# ==========================
# Miscellaneous
# ==========================
*.tmp
*.temp